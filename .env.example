WORKOS_CLIENT_ID=client_...
WORKOS_API_KEY=sk_test_...
WORKOS_COOKIE_PASSWORD=replace-with-a-32-plus-character-secret
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
ALLOWED_EMAIL=you@example.com
CALENDAR_FEED_TOKEN=replace-with-a-random-long-secret

# Supabase (recommended for durable storage on Vercel)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_TASKS_TABLE=tasks

# Compatibility aliases (supported by code if you already used these names)
SUPPERBASE_PROJECT_URI=
SUPPERBASE_KEY=

# File storage fallback (used only when Supabase env is not configured)
TASKS_STORAGE_FILE=.data/glass-todo-tasks.json
